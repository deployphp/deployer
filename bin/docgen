namespace Deployer;

use Deployer\Documentation\ApiGen;
use Deployer\Documentation\DocGen;
use Deployer\Import\MamlRecipe;
use Maml\Maml;
use Symfony\Component\Console\Application;
use Symfony\Component\Console\Input\ArgvInput;
use Symfony\Component\Console\Output\ConsoleOutput;

require __DIR__ . '/../vendor/autoload.php';

chdir(realpath(__DIR__ . '/..'));

$input = new ArgvInput();
$output = new ConsoleOutput();
$app = new Application('DocGen', '1.0.0');
$app->setDefaultCommand('all');

$api = function () use ($output): int {
    $parser = new ApiGen();
    $parser->parse(file_get_contents(__DIR__ . '/../src/functions.php'));
    $md = $parser->markdown();
    file_put_contents(__DIR__ . '/../docs/api.md', $md);
    $output->writeln('API Reference documentation updated.');
    return 0;
};

$recipes = function () use ($input, $output): int {
    $docgen = new DocGen(__DIR__ . '/..');
    $docgen->parse(__DIR__ . '/../recipe');
    $docgen->parse(__DIR__ . '/../contrib');

    if ($input->getOption('json')) {
        echo json_encode($docgen->recipes, JSON_PRETTY_PRINT);
        return 0;
    }

    $docgen->gen(__DIR__ . '/../docs');
    $output->writeln('Recipes documentation updated.');
    return 0;
};

$schema = function () use ($output): int {
    $newSchema = [
        '$id' => "https://deployer.org/schema.json#",
        ...Maml::jsonSchema(MamlRecipe::schema()),
    ];
    file_put_contents(__DIR__ . '/../src/schema.json', json_encode($newSchema, JSON_PRETTY_PRINT));
    $output->writeln('Schema updated.');
    return 0;
};

$app->register('api')->setCode($api);
$app->register('recipes')->setCode($recipes)->addOption('json');
$app->register('schema')->setCode($schema);
$app->register('all')->setCode(function () use ($schema, $recipes, $api): int {
    $api();
    $recipes();
    $schema();
    echo shell_exec('git status');
    return 0;
})->addOption('json');

$app->run($input, $output);
